# ═══════════════════════════════════════════════════════════════
# .env.example - Environment Variables Template
# Copy this to .env.local for local development
# NEVER commit .env files to version control
# ═══════════════════════════════════════════════════════════════

# ─── Application ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_NAME=github-aws-pipeline-app
APP_VERSION=1.0.0
LOG_LEVEL=info

# ─── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# ─── AWS Configuration ──────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
ECR_REPOSITORY_NAME=github-aws-pipeline
ECR_REPOSITORY=123456789012.dkr.ecr.us-east-1.amazonaws.com/github-aws-pipeline

# ─── CodePipeline / CodeDeploy ──────────────────────────────────
PIPELINE_NAME=github-aws-codedeploy-pipeline
CODEDEPLOY_APP=github-aws-pipeline-app
CODEDEPLOY_GROUP=github-aws-pipeline-group
DEPLOYMENT_STAGE=production

# ─── Deployment Metadata (auto-set by CodeBuild/CodeDeploy) ─────
DEPLOY_TIMESTAMP=
DEPLOYMENT_ID=
DOCKER_IMAGE=
IMAGE_TAG=latest
GIT_COMMIT=
CODEBUILD_BUILD_ID=
CODEBUILD_RESOLVED_SOURCE_VERSION=
